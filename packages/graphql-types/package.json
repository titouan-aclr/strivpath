    "graphql": "^16.0.0"
  },
  "devDependencies": {
    "@nestjs/graphql": "^13.1.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.11.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "eslint": "^8.57.0",
    "graphql": "^16.10.0",
    "typescript": "5.5.4"
  }
