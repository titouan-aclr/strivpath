{
  "name": "@repo/graphql-types",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist-cjs/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsc && tsc --project tsconfig.cjs.json && cp package.cjs.json dist-cjs/package.json",
    "dev": "tsc --watch",
