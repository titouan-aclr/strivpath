# Databse
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/strivpath"

# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3011/v1/auth/strava/callback

# JWT Secrets
JWT_ACCESS_TOKEN_SECRET=your_access_token_secret_here
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# JWT Expiration
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Cookie Configuration
COOKIES_SAME_SITE=lax
COOKIES_SECURE=false

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
PORT=3011
NODE_ENV=development

# Token Cleanup (cronjob)
TOKEN_CLEANUP_ENABLED=true

# Rate Limiting (Throttler)
# Protects authentication endpoints against abuse and DDoS attacks
# TTL in milliseconds, limit is requests per TTL period

# Default for non-auth endpoints (100 requests per 60 seconds)
THROTTLE_DEFAULT_TTL=60000
THROTTLE_DEFAULT_LIMIT=100

# Strava Webhook
# Used for subscription validation (challenge-response)
# Generate with: openssl rand -hex 20
STRAVA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Note: Specific endpoint limits are hardcoded in decorators:
# - OAuth callback: 5 req/min
# - Token refresh: 10 req/min
# - Logout: 5 req/min
