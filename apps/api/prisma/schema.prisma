// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int       @id @default(autoincrement())
  stravaId      Int       @unique
  username      String?
  firstname     String?
  lastname      String?
  sex           String?
  city          String?
  country       String?
  profile       String?
  profileMedium String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tokens        StravaToken[]
  preferences   UserPreferences?
  activities    Activity[]
  syncHistory   SyncHistory[]
  refreshTokens RefreshToken[]
  goals         Goal[]
}

model StravaToken {
  id           Int      @id @default(autoincrement())
  accessToken  String
  refreshToken String
  expiresAt    Int
  createdAt    DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  selectedSports       Json
  onboardingCompleted  Boolean  @default(false)
  locale               String   @default("en")
  theme                String   @default("system")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id                   Int      @id @default(autoincrement())
  stravaId             BigInt   @unique
  userId               Int
  name                 String
  type                 String
  distance             Float
  movingTime           Int
  elapsedTime          Int
  totalElevationGain   Float
  startDate            DateTime
  startDateLocal       DateTime
  timezone             String
  averageSpeed         Float?
  maxSpeed             Float?
  averageHeartrate     Float?
  maxHeartrate         Float?
  kilojoules           Float?
  deviceWatts          Boolean?
  hasKudoed            Boolean  @default(false)
  kudosCount           Int      @default(0)
  averageCadence       Float?
  elevHigh             Float?
  elevLow              Float?
  calories             Float?
  splits               Json?
  averageWatts         Float?
  weightedAverageWatts Float?
  maxWatts             Int?
  raw                  Json
  description          String?
  detailsFetched       Boolean  @default(false)
  detailsFetchedAt     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([userId, type])
}

model SyncHistory {
  id                   Int       @id @default(autoincrement())
  userId               Int
  status               String
  stage                String?
  totalActivities      Int       @default(0)
  processedActivities  Int       @default(0)
  errorMessage         String?
  startedAt            DateTime  @default(now())
  completedAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  jti        String    @unique
  expiresAt  DateTime
  revoked    Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@index([jti, revoked])
}

model GoalTemplate {
  id          Int      @id @default(autoincrement())
  targetType  String
  targetValue Float
  periodType  String
  sportType   String?
  category    String
  isPreset    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goals        Goal[]
  translations GoalTemplateTranslation[]

  @@index([category])
}

model GoalTemplateTranslation {
  id          Int      @id @default(autoincrement())
  templateId  Int
  locale      String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template GoalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
  @@index([locale])
}

model Goal {
  id                Int       @id @default(autoincrement())
  userId            Int
  title             String
  description       String?
  targetType        String
  targetValue       Float
  periodType        String
  startDate         DateTime
  endDate           DateTime
  isRecurring       Boolean   @default(false)
  recurrenceEndDate DateTime?
  templateId        Int?
  sportType         String?
  status            String    @default("ACTIVE")
  currentValue      Float     @default(0)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template GoalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, endDate])
  @@index([userId, sportType])
  @@index([templateId])
}
