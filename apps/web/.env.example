# GraphQL API endpoint
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3011/graphql

# Public base URL of the application (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_APP_URL=https://example.com

# Base URL for legal pages (legal notice, privacy policy, terms of use)
# These pages are hosted on a separate application
NEXT_PUBLIC_LEGAL_BASE_URL=https://example.com

# Umami Analytics (self-hosted)
# Script URL: https://your-umami-instance.com/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
# Website ID from your Umami dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Restrict tracking to these domains only (comma-separated) — prevents local dev from polluting prod stats
# Example: strivpath.com,www.strivpath.com
NEXT_PUBLIC_UMAMI_DOMAINS=
