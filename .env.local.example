# =============================================================================
# StrivPath - Environment Variables for Local Docker Testing
# =============================================================================
#
# Copy this file to .env and fill in the values.
# This file is used by docker-compose.local.yml
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=strivpath

# -----------------------------------------------------------------------------
# JWT Secrets (minimum 32 characters each)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET=local-dev-jwt-access-secret-min-32-chars
JWT_REFRESH_TOKEN_SECRET=local-dev-jwt-refresh-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Strava OAuth (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: https://www.strava.com/settings/api
# Set the Authorization Callback Domain to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
