# =============================================================================
# StrivPath - Environment Variables for Local Docker Testing
# =============================================================================
#
# Copy this file to .env and fill in the values.
# This file is used by docker-compose.local.yml
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=strivpath

# -----------------------------------------------------------------------------
# JWT Secrets (minimum 32 characters each)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET=local-dev-jwt-access-secret-min-32-chars
JWT_REFRESH_TOKEN_SECRET=local-dev-jwt-refresh-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Strava OAuth (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: https://www.strava.com/settings/api
# Set the Authorization Callback Domain to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Strava Webhook
# -----------------------------------------------------------------------------
# Used for webhook subscription validation (challenge-response)
# Generate with: openssl rand -hex 20
STRAVA_WEBHOOK_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Public base URL of the application (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL where legal pages are hosted (legal notice, privacy policy, terms)
NEXT_PUBLIC_LEGAL_BASE_URL=https://example.com
