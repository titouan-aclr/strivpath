# =============================================================================
# StrivPath - Environment Variables for Production (Dokploy)
# =============================================================================
#
# Configure these variables in Dokploy UI (Environment Variables section)
# or copy to .env.prod for manual deployment.
#
# This file is used by docker-compose.prod.yml
#
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# Your main domain (without protocol)
# Web will be accessible at: https://DOMAIN
# API will be accessible at: https://api.DOMAIN
DOMAIN=strivpath.mydomain.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=strivpath
POSTGRES_PASSWORD=
POSTGRES_DB=strivpath

# -----------------------------------------------------------------------------
# JWT Secrets (minimum 32 characters each)
# -----------------------------------------------------------------------------
# IMPORTANT: Use strong, unique secrets in production!
# Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Strava OAuth (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: https://www.strava.com/settings/api
# Set the Authorization Callback Domain to: your-domain.com
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Strava Webhook (REQUIRED)
# -----------------------------------------------------------------------------
# Used for webhook subscription validation (challenge-response)
# IMPORTANT: Use a strong, unique token in production!
# Generate with: openssl rand -hex 20
STRAVA_WEBHOOK_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Docker Images (Optional - defaults to latest)
# -----------------------------------------------------------------------------
# API_TAG=latest
# WEB_TAG=latest

# -----------------------------------------------------------------------------
# Frontend (REQUIRED)
# -----------------------------------------------------------------------------
# Public base URL of the application — must match your DOMAIN setting
NEXT_PUBLIC_APP_URL=https://strivpath.mydomain.com
# Base URL where legal pages are hosted (legal notice, privacy policy, terms)
NEXT_PUBLIC_LEGAL_BASE_URL=https://example.com
