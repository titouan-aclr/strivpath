# =============================================================================
# Stravanalytics - Environment Variables for Production (Dokploy)
# =============================================================================
#
# Configure these variables in Dokploy UI (Environment Variables section)
# or copy to .env.prod for manual deployment.
#
# This file is used by docker-compose.prod.yml
#
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# Your main domain (without protocol)
# Web will be accessible at: https://DOMAIN
# API will be accessible at: https://api.DOMAIN
DOMAIN=stravanalytics.mydomain.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=stravanalytics
POSTGRES_PASSWORD=
POSTGRES_DB=stravanalytics

# -----------------------------------------------------------------------------
# JWT Secrets (minimum 32 characters each)
# -----------------------------------------------------------------------------
# IMPORTANT: Use strong, unique secrets in production!
# Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Strava OAuth (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: https://www.strava.com/settings/api
# Set the Authorization Callback Domain to: stravanalytics.titouanauclair.com
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Docker Images (Optional - defaults to latest)
# -----------------------------------------------------------------------------
# API_TAG=latest
# WEB_TAG=latest
